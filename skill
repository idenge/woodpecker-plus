> **Why curl_cffi, not requests?**  
> Sci-Hub mirrors (especially via CDN like hkvisa.net) perform TLS fingerprint checks. Plain `requests` uses Python's default TLS stack which gets detected and blocked (connection timeout). `curl_cffi` with `impersonate="chrome131"` mimics Chrome's exact TLS handshake, passing the check.

### Fetch + Parse Pattern

```python
from curl_cffi import requests as creq
from bs4 import BeautifulSoup

def fetch_and_parse(doi, scihub_url, timeout=30):
    url = scihub_url.rstrip("/") + "/" + doi.strip()
    r = creq.get(url, timeout=timeout, verify=False,
                 impersonate="chrome131", allow_redirects=True)
    if r.status_code != 200:
        raise DownloadError(f"HTTP {r.status_code}")

    soup = BeautifulSoup(r.text, "html.parser")

    # Priority order for PDF URL extraction:
    # 1. iframe#pdf (classic Sci-Hub layout)
    iframe = soup.find("iframe", attrs={"id": "pdf"})
    if iframe and iframe.get("src"):
        return normalize(iframe["src"])

    # 2. Any iframe with 'pdf' in src
    for iframe in soup.find_all("iframe"):
        src = iframe.get("src", "")
        if "pdf" in src.lower():
            return normalize(src)

    # 3. embed[type="application/pdf"]
    embed = soup.find("embed", attrs={"type": "application/pdf"})
    if embed and embed.get("src"):
        return normalize(embed["src"])

    # 4. Regex fallback
    import re
    matches = re.findall(r'(https?://[^\s"\'<>]+\.pdf[^\s"\'<>]*)', r.text)
    if matches:
        return matches[0]

    raise DownloadError("article not found")
```

### PDF Download with Validation

```python
def download_pdf(pdf_url, save_path, timeout=60):
    r = creq.get(pdf_url, timeout=timeout, verify=False, impersonate="chrome131")
    if r.status_code != 200:
        raise DownloadError(f"HTTP {r.status_code}")
    with open(save_path, "wb") as f:
        f.write(r.content)
    # Validate PDF header
    with open(save_path, "rb") as f:
        if f.read(5) != b'%PDF-':
            os.remove(save_path)
            raise DownloadError("not a valid PDF")
    return len(r.content)
```

### Multi-Mirror Failover

```python
def fetch_article(doi, mirrors, save_dir):
    safe_name = re.sub(r'[\\/:*?"<>|]', '_', doi) + ".pdf"
    save_path = os.path.join(save_dir, safe_name)
    for mirror in mirrors:
        try:
            pdf_url = fetch_and_parse(doi, mirror)
            size = download_pdf(pdf_url, save_path)
            return True, save_path, size, mirror
        except Exception:
            continue
    return False, None, 0, None
```

